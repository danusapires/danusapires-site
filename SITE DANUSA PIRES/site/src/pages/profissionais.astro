---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfessionalCard from '../components/ProfessionalCard.astro';
import CtaSection from '../components/CtaSection.astro';
import { SITE } from '../data/site';
import { professionals, getProfessionalBySlug } from '../data/professionals';

const danusa = getProfessionalBySlug('danusa-pires');
const adriana = getProfessionalBySlug('adriana-melo');
const equipe = getProfessionalBySlug('equipe-tecnica');
---

<BaseLayout
  title="Profissionais"
  description="A equipe clínica da Dra. Danusa Pires: tricologia avançada conduzida pela fundadora e abordagem integrativa em terapias holísticas com Adriana Melo. Cada profissional ocupa função clara dentro do protocolo."
  currentPage="profissionais"
  breadcrumbs={[{ name: 'Profissionais', url: '/profissionais' }]}
>

  <!-- Schema: MedicalOrganization -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MedicalOrganization",
    "name": SITE.name,
    "url": SITE.url,
    "member": professionals.map(p => ({
      "@type": "Person",
      "name": p.name,
      "jobTitle": p.role,
      "url": `${SITE.url}/profissionais/${p.slug}`,
    }))
  })} />

  <!-- HERO -->
  <section class="hero" style="min-height:50vh">
    <div class="hero-content">
      <p class="lbl r">equipe</p>
      <h1 class="r d1">Equipe clínica <em>alinhada</em>.</h1>
      <p class="r d2">Profissionais com função clara dentro do protocolo. Da avaliação inicial ao acompanhamento, cada etapa tem responsabilidade técnica definida.</p>
    </div>
  </section>

  <!-- TRICOLOGIA — Dra. Danusa Pires + equipe técnica -->
  {danusa && (
    <section>
      <div style="max-width:780px">
        <p class="lbl r">tricologia avançada</p>
        <h2 class="section-title r d1">Conduzida pela <em>fundadora</em>.</h2>
      </div>

      <div class="pf-feature">
        <picture class="pf-feature-img r">
          {danusa.photo && <source srcset="/team/danusa-pires-hero.avif" type="image/avif" />}
          {danusa.photo && <source srcset={danusa.photo} type="image/webp" />}
          <img src={danusa.photo || ''} alt={danusa.name} loading="lazy" decoding="async" />
        </picture>
        <div class="pf-feature-body r d1">
          <p class="pf-feature-role">{danusa.role}</p>
          {danusa.registration && <p class="pf-feature-reg">{danusa.registration}</p>}
          <p class="pf-feature-desc">{danusa.description}</p>
          <ul class="pf-feature-tags">
            {danusa.tags.map(t => <li>{t}</li>)}
          </ul>
          <a href={`/profissionais/${danusa.slug}`} class="pf-feature-link">ver perfil completo →</a>
        </div>
      </div>

      {equipe && (
        <div style="margin-top:var(--space-xl);max-width:560px;padding-top:var(--space-lg);border-top:1px solid rgba(232,227,220,.1)">
          <p class="lbl r" style="margin-bottom:12px">equipe técnica</p>
          <p class="r d1" style="font-size:14px;line-height:1.85;color:var(--color-ink-soft)">{equipe.description}</p>
        </div>
      )}
    </section>
  )}

  <!-- TERAPIAS HOLÍSTICAS — Adriana Melo, bloco escuro destacado -->
  {adriana && (
    <section class="section-cream">
      <div style="max-width:780px">
        <p class="lbl r">terapias holísticas</p>
        <h2 class="section-title r d1">Camada <em>integrativa</em> ao protocolo capilar.</h2>
        <p class="section-subtitle r d2">A biorressonância opera como leitura energético-funcional complementar à tricologia. Não substitui a investigação clínica — soma. A indicação parte da articulação entre as duas frentes.</p>
      </div>

      <div class="pf-feature pf-feature-alt">
        <div class="pf-feature-body r d1">
          <p class="pf-feature-role">{adriana.role}</p>
          {adriana.registration && !adriana.registration.startsWith('TODO') && (
            <p class="pf-feature-reg">{adriana.registration}</p>
          )}
          <p class="pf-feature-desc">{adriana.description}</p>
          <ul class="pf-feature-tags">
            {adriana.tags.map(t => <li>{t}</li>)}
          </ul>
          <div class="pf-feature-actions">
            <a href="/terapias-holisticas" class="btn btn-outline">conhecer terapias holísticas</a>
            <a href={`/profissionais/${adriana.slug}`} class="pf-feature-link">ver perfil →</a>
          </div>
        </div>
        <picture class="pf-feature-img r">
          {adriana.photo && <source srcset="/team/adriana-melo.avif" type="image/avif" />}
          {adriana.photo && <source srcset={adriana.photo} type="image/webp" />}
          <div class="pf-feature-fallback" style={`background:${adriana.bg}`} aria-hidden="true">
            <span>{adriana.name.split(' ').map(s=>s[0]).join('').slice(0,2)}</span>
          </div>
        </picture>
      </div>
    </section>
  )}

  <!-- CTA Final -->
  <CtaSection
    heading="Atendimento conduzido por <em>profissionais</em> com função definida."
    subtext="Triagem inicial pelo WhatsApp. A equipe organiza a avaliação correta antes do agendamento."
  />

  <style>
    .pf-feature {
      display: grid;
      grid-template-columns: 380px 1fr;
      gap: clamp(2rem, 5vw, 4rem);
      align-items: start;
      margin-top: var(--space-xl);
    }
    .pf-feature-alt {
      grid-template-columns: 1fr 380px;
    }
    @media (max-width: 800px) {
      .pf-feature, .pf-feature-alt { grid-template-columns: 1fr; }
    }

    .pf-feature-img {
      aspect-ratio: 3/4;
      overflow: hidden;
      background: var(--c-graphite);
      display: block;
    }
    .pf-feature-img img,
    .pf-feature-img picture {
      width: 100%; height: 100%; object-fit: cover; display: block;
    }
    .pf-feature-fallback {
      width: 100%; height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--c-beige);
      font-family: var(--font-serif);
      font-size: 80px;
      font-weight: 400;
      letter-spacing: 0.02em;
    }
    .pf-feature-body {
      padding-top: 8px;
    }
    .pf-feature-role {
      font-family: var(--font-primary);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--c-gold);
      margin-bottom: 12px;
    }
    .pf-feature-reg {
      font-family: var(--font-primary);
      font-size: 12px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--color-ink-ghost);
      margin-bottom: var(--space-md);
    }
    .pf-feature-desc {
      font-size: 15px;
      line-height: 1.85;
      color: var(--color-ink-soft);
      max-width: 60ch;
      margin-bottom: var(--space-md);
    }
    .pf-feature-tags {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      padding: 0;
      margin: 0 0 var(--space-md);
    }
    .pf-feature-tags li {
      font-family: var(--font-primary);
      font-size: 11px;
      letter-spacing: 0.06em;
      padding: 5px 14px;
      border: 1px solid rgba(232,227,220,.18);
      color: var(--color-ink-soft);
    }
    .section-cream .pf-feature-tags li {
      border-color: rgba(11,11,11,.18);
      color: rgba(11,11,11,.65);
    }
    .pf-feature-link {
      display: inline-block;
      font-family: var(--font-primary);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--c-gold);
      border-bottom: 1px solid var(--c-gold);
      padding-bottom: 3px;
      margin-top: 8px;
    }
    .pf-feature-link:hover { color: var(--color-ink); }
    .pf-feature-actions {
      display: flex;
      gap: var(--space-md);
      align-items: center;
      flex-wrap: wrap;
      margin-top: 8px;
    }
  </style>

</BaseLayout>
