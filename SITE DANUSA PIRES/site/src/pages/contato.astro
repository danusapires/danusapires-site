---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, WA_DEFAULT } from '../data/site';
---

<BaseLayout
  title="Contato"
  description="Fale pelo WhatsApp ou agende sua avaliação na clínica de Porto Alegre, Edifício Moinhos 180. Atendimento online para casos selecionados em todo o Brasil."
  currentPage="contato"
  breadcrumbs={[{ name: 'Contato', url: '/contato' }]}
>

  <section class="hero" style="min-height:auto;padding-top:140px;padding-bottom:var(--section-py)">
    <div style="max-width:1080px;width:100%">
      <p class="lbl r">contato</p>
      <h1 class="r d1" style="font-size:clamp(32px,4vw,42px)">Onde nos <em>encontrar</em></h1>

      <div class="g2" style="margin-top:var(--space-xl);gap:var(--space-xl);align-items:start">
        <div class="r">
          <p class="lbl" style="margin-bottom:var(--space-sm)">sede · porto alegre</p>
          <h2 style="font-family:var(--font-serif);font-style:italic;font-size:24px;font-weight:400;margin-bottom:var(--space-md)">{SITE.address.complement.split('—')[1]?.trim() || 'Edifício Moinhos 180'}</h2>
          <address style="font-size:14px;line-height:2;color:var(--color-ink-soft);font-style:normal">
            <p>{SITE.address.street}, {SITE.address.number}</p>
            <p>{SITE.address.complement}</p>
            <p>{SITE.address.neighborhood} · {SITE.address.city} — {SITE.address.state}</p>
            <p style="margin-top:var(--space-sm)"><strong style="color:var(--color-ink)">{SITE.phone}</strong></p>
          </address>

          <div style="margin-top:var(--space-md);padding-top:var(--space-md);border-top:1px solid var(--color-stone)">
            <p class="lbl" style="margin-bottom:var(--space-sm)">atendimento online</p>
            <p style="font-size:14px;color:var(--color-ink-soft);line-height:1.7">{SITE.onlineCare}.</p>
          </div>

          <div style="margin-top:var(--space-lg);display:flex;gap:12px;flex-wrap:wrap">
            <a href={WA_DEFAULT} target="_blank" rel="noopener noreferrer" class="btn btn-primary">falar pelo whatsapp</a>
            <a href={SITE.mapsUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline">ver no mapa</a>
          </div>
        </div>

        <div class="r d1" style="aspect-ratio:4/5;border-radius:2px;overflow:hidden;background:var(--color-cream)">
          <iframe
            title="Localização da Sede — Edifício Moinhos 180, Porto Alegre"
            src="https://www.google.com/maps?q=Rua+Mariante+180+Moinhos+de+Vento+Porto+Alegre&output=embed"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            style="width:100%;height:100%;border:0;display:block;filter:grayscale(0.15) contrast(0.95)"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
