---
import { SITE, NAV_LINKS, PILLARS } from '../data/site';
---

<footer class="footer">
  <div class="footer-grid">
    <div class="footer-brand">
      <p class="footer-logo-text">Danusa <em class="footer-logo-italic">Pires</em><br><span class="footer-logo-desc">tricologia & saúde integrativa</span></p>
      <p class="footer-position">{SITE.tagline}</p>
    </div>

    <div>
      <h4>endereço</h4>
      <p style="line-height:1.85">
        <strong style="color:var(--c-beige);font-weight:500">Sede · Porto Alegre</strong><br>
        {SITE.address.street}, {SITE.address.number}<br>
        {SITE.address.complement}<br>
        {SITE.address.neighborhood} · {SITE.address.city}, {SITE.address.state}
      </p>
      <p style="line-height:1.85;margin-top:16px;color:var(--c-gold);font-size:11px;letter-spacing:.14em;text-transform:uppercase">{SITE.onlineCare}</p>
    </div>

    <div>
      <h4>navegação</h4>
      <ul class="footer-links">
        {NAV_LINKS.filter(l => l.href.startsWith('/') && !l.href.includes('#')).map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
      <h4 style="margin-top:32px">serviços</h4>
      <ul class="footer-links">
        {PILLARS.slice(0, 4).map(p => (
          <li><a href="/#servicos">{p.name}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h4>contato</h4>
      <ul class="footer-links">
        <li><a href={`tel:${SITE.phone.replace(/\s/g,'')}`}>{SITE.phone}</a></li>
        <li><a href={`https://instagram.com/${SITE.instagram.replace('@','')}`} target="_blank" rel="noopener noreferrer">{SITE.instagram}</a></li>
        <li><a href="/agendamento">agendar avaliação</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <p>
      {SITE.address.neighborhood} · {SITE.address.city}
      <span style="color:var(--color-ink-ghost)">{SITE.cnpj && SITE.cnpj.startsWith('TODO') ? '' : ` · CNPJ ${SITE.cnpj}`}</span>
    </p>
    <p style="margin-top:10px">
      <a href="/politica-de-privacidade">política de privacidade</a>
      <span style="color:var(--c-gold);margin:0 8px">·</span>
      <a href="/termos-de-uso">termos de uso</a>
    </p>
    <p style="margin-top:24px;font-size:10px;color:var(--color-ink-ghost);max-width:600px;line-height:1.7">
      Resposta variável conforme padrão fisiológico individual. Conduta definida conforme avaliação clínica. Evolução dependente de causa, adesão, tempo e resposta individual.
    </p>
  </div>
</footer>

<style>
  .footer-brand .footer-logo-text {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 400;
    line-height: 1.15;
    color: var(--c-beige);
    letter-spacing: -0.012em;
    margin-bottom: 16px;
  }
  .footer-brand .footer-logo-italic {
    font-style: italic;
    color: var(--c-gold);
  }
  .footer-brand .footer-logo-desc {
    font-family: var(--font-primary);
    font-style: normal;
    color: rgba(232,227,220,.55);
    font-size: 11px;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    display: inline-block;
    margin-top: 8px;
  }
  .footer-brand .footer-position {
    font-size: 13px;
    color: var(--color-ink-soft);
    line-height: 1.75;
    max-width: 36ch;
    font-weight: 300;
  }
</style>
