---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaSection from '../../components/CtaSection.astro';
import { professionals } from '../../data/professionals';
import { SITE, WA_BASE } from '../../data/site';

export async function getStaticPaths() {
  return professionals.map(p => ({
    params: { slug: p.slug },
    props: { pro: p },
  }));
}

const { pro } = Astro.props as any;
const waMessage = encodeURIComponent(`Olá, gostaria de agendar uma avaliação com ${pro.name}.`);
const waLink = `${WA_BASE}?text=${waMessage}`;
const igUrl = pro.ig ? `https://instagram.com/${pro.ig.replace('@','')}` : null;
---

<BaseLayout
  title={pro.name}
  description={pro.description.slice(0, 160)}
  currentPage="profissionais"
  breadcrumbs={[
    { name: 'Profissionais', url: '/profissionais' },
    { name: pro.name, url: `/profissionais/${pro.slug}` },
  ]}
>

  <!-- Schema: Person -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": pro.name,
    "jobTitle": pro.role,
    "identifier": pro.registration && !pro.registration.startsWith('TODO') ? pro.registration : undefined,
    "worksFor": {
      "@type": "MedicalBusiness",
      "name": SITE.name,
      "url": SITE.url,
    },
    "knowsAbout": pro.specialties || [],
    "url": `${SITE.url}/profissionais/${pro.slug}`,
    ...(igUrl ? { sameAs: [igUrl] } : {}),
  })} />

  <!-- HERO -->
  <section class="pp-hero">
    <div class="pp-hero-image" aria-hidden="true">
      {pro.photo ? (
        <picture>
          <source srcset={pro.slug === 'danusa-pires' ? '/team/danusa-pires-hero.avif' : pro.photo.replace('.webp', '.avif')} type="image/avif" />
          <source srcset={pro.slug === 'danusa-pires' ? '/team/danusa-pires-hero.webp' : pro.photo} type="image/webp" />
          <img src={pro.photo} alt={pro.name} fetchpriority="high" decoding="async" />
        </picture>
      ) : (
        <div class="pp-hero-fallback" style={`background:${pro.bg}`}>
          <span>{pro.name.split(' ').map((s: string) => s[0]).join('').slice(0, 2)}</span>
        </div>
      )}
    </div>

    <div class="pp-hero-content">
      <p class="lbl r">profissional</p>
      <h1 class="pp-hero-title r d1">{pro.name}</h1>
      <p class="pp-hero-role r d2">{pro.role}</p>
      {pro.registration && !pro.registration.startsWith('TODO') && (
        <p class="pp-hero-reg r d3">{pro.registration}</p>
      )}
      <div class="pp-hero-actions r d3">
        <a href={waLink} target="_blank" rel="noopener noreferrer" class="btn btn-primary">agendar com {pro.name.split(' ')[0]}</a>
        {igUrl && (
          <a href={igUrl} target="_blank" rel="noopener noreferrer" class="pp-ig-link">{pro.ig} →</a>
        )}
      </div>
    </div>
  </section>

  <!-- BIO -->
  <section class="section-cream">
    <div class="g2" style="align-items:start;gap:var(--space-2xl)">
      <div>
        <p class="lbl r">trajetória</p>
        <h2 class="section-title r d1">Como conduz <em>cada caso</em>.</h2>
      </div>
      <div class="r d2">
        <p class="pp-bio">{pro.description}</p>

        {pro.education && (
          <div class="pp-block">
            <p class="pp-block-title">formação</p>
            <ul class="pp-block-list">
              <li>{pro.education.graduation}</li>
              {pro.education.postgrad?.map((p: string) => !p.startsWith('TODO') && <li>{p}</li>)}
              {pro.education.residency && !pro.education.residency.startsWith('TODO') && <li>{pro.education.residency}</li>}
            </ul>
          </div>
        )}

        {pro.specialties && pro.specialties.length > 0 && (
          <div class="pp-block">
            <p class="pp-block-title">especialidades</p>
            <ul class="pp-block-list">
              {pro.specialties.map((s: string) => <li>{s}</li>)}
            </ul>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- QUEIXAS PRINCIPAIS -->
  {pro.mainComplaints && pro.mainComplaints.length > 0 && (
    <section>
      <div style="max-width:780px">
        <p class="lbl r">queixas principais</p>
        <h2 class="section-title r d1">Quadros que chegam ao <em>{pro.name.split(' ')[0]}</em>.</h2>
      </div>

      <ul class="pp-complaints r d2">
        {pro.mainComplaints.map((c: string) => <li>{c}</li>)}
      </ul>
    </section>
  )}

  <CtaSection
    heading={`Avaliação com <em>${pro.name.split(' ').slice(0, 2).join(' ')}</em>.`}
    subtext="A primeira conversa pelo WhatsApp adianta a triagem antes da avaliação presencial. Conduta definida conforme leitura individual."
  />

  <style>
    /* HERO */
    .pp-hero {
      min-height: 78vh;
      display: grid;
      grid-template-columns: 1fr 1.05fr;
      background: var(--c-black);
      overflow: hidden;
    }
    .pp-hero-image { position: relative; overflow: hidden; background: var(--c-graphite); }
    .pp-hero-image picture, .pp-hero-image img {
      width: 100%; height: 100%; object-fit: cover; display: block;
    }
    .pp-hero-image::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(90deg, transparent 60%, rgba(11,11,11,0.5) 100%);
    }
    .pp-hero-fallback {
      width: 100%; height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--c-beige);
      font-family: var(--font-serif);
      font-size: 120px;
      font-weight: 400;
      letter-spacing: 0.04em;
    }
    .pp-hero-content {
      padding: clamp(7rem, 14vh, 10rem) clamp(2rem, 6vw, 5rem) clamp(3rem, 8vh, 5rem);
      display: flex;
      flex-direction: column;
      justify-content: center;
      max-width: 720px;
    }
    .pp-hero-title {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: clamp(40px, 5.6vw, 80px);
      line-height: 1.05;
      letter-spacing: -0.02em;
      color: var(--c-beige);
      margin: 0 0 12px;
    }
    .pp-hero-role {
      font-family: var(--font-primary);
      font-size: 13px;
      font-weight: 400;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--c-gold);
      margin-bottom: 12px;
    }
    .pp-hero-reg {
      font-family: var(--font-primary);
      font-size: 12px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--color-ink-ghost);
      margin-bottom: var(--space-lg);
    }
    .pp-hero-actions {
      display: flex;
      align-items: center;
      gap: 24px;
      flex-wrap: wrap;
    }
    .pp-ig-link {
      font-family: var(--font-primary);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--c-beige);
      border-bottom: 1px solid var(--c-gold);
      padding-bottom: 3px;
      transition: color var(--transition-fast);
    }
    .pp-ig-link:hover { color: var(--c-gold); }
    @media (max-width: 960px) {
      .pp-hero { grid-template-columns: 1fr; min-height: auto; }
      .pp-hero-image { aspect-ratio: 4/5; }
      .pp-hero-content { padding-top: 4rem; }
    }

    /* BIO */
    .pp-bio {
      font-size: 16px;
      line-height: 1.85;
      color: var(--color-ink-soft);
      max-width: 60ch;
      margin-bottom: var(--space-xl);
    }
    .pp-block {
      margin-top: var(--space-lg);
      padding-top: var(--space-md);
      border-top: 1px solid rgba(11,11,11,.12);
    }
    .pp-block-title {
      font-family: var(--font-primary);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--c-gold);
      margin-bottom: var(--space-sm);
    }
    .pp-block-list {
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .pp-block-list li {
      font-family: var(--font-serif);
      font-size: 17px;
      font-weight: 400;
      color: var(--c-black);
      line-height: 1.4;
      padding-left: 18px;
      position: relative;
    }
    .pp-block-list li::before {
      content: '·';
      position: absolute;
      left: 0;
      color: var(--c-gold);
      font-size: 22px;
      line-height: 1;
      top: 0;
    }

    /* QUEIXAS */
    .pp-complaints {
      list-style: none;
      padding: 0;
      margin: var(--space-xl) 0 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0;
      border-top: 1px solid rgba(232,227,220,.1);
    }
    .pp-complaints li {
      padding: var(--space-md) var(--space-lg) var(--space-md) calc(var(--space-lg) + 30px);
      border-bottom: 1px solid rgba(232,227,220,.08);
      font-family: var(--font-serif);
      font-size: 17px;
      color: var(--c-beige);
      position: relative;
    }
    .pp-complaints li:nth-child(odd) { border-right: 1px solid rgba(232,227,220,.08); }
    .pp-complaints li::before {
      content: '·';
      position: absolute;
      left: var(--space-lg);
      color: var(--c-gold);
      font-size: 22px;
      top: 50%;
      transform: translateY(-50%);
    }
    @media (max-width: 720px) {
      .pp-complaints { grid-template-columns: 1fr; }
      .pp-complaints li:nth-child(odd) { border-right: 0; }
    }
  </style>

</BaseLayout>
