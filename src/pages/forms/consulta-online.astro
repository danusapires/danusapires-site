---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE, FORM_TYPES, WA_DEFAULT } from '../../data/site';

const formConfig = FORM_TYPES.onlineConsultation;
---

<BaseLayout
  title="Consulta online | Danusa Pires"
  description="Avaliação capilar online estruturada para casos selecionados em todo o Brasil. Diagnóstico e protocolo personalizado por telemedicina."
  currentPage="consulta-online"
  breadcrumbs={[
    { name: 'Consulta online', url: '/forms/consulta-online' }
  ]}
>

  <!-- HERO -->
  <section class="form-hero">
    <div class="form-hero-content">
      <p class="lbl r">avaliação remota</p>
      <h1 class="form-hero-title r d1">
        Consulta <em>capilar online</em>.
      </h1>
      <p class="form-hero-lead r d2">
        Atendimento estruturado de qualquer região do Brasil. Avaliação com tricoscopia digital compartilhada. Diagnóstico e protocolo definido por telemedicina com segurança clínica.
      </p>
    </div>
  </section>

  <!-- FORM SECTION -->
  <section style="padding:var(--section-py) var(--section-px)">
    <div class="form-container r d1">
      <div class="form-header">
        <h2>Solicite sua consulta online</h2>
        <p>Selecione uma data e hora disponível. Receberá link de telemedicina 24h antes da avaliação.</p>
      </div>

      <form class="ecooa-form" action={SITE.gasUrl} method="POST">
        <input type="hidden" name="_formType" value={formConfig.id} />

        <!-- NOME -->
        <fieldset class="form-field r">
          <label for="nome">Nome completo *</label>
          <input type="text" id="nome" name="nome" placeholder="Seu nome" required />
        </fieldset>

        <!-- EMAIL -->
        <fieldset class="form-field r">
          <label for="email">Email *</label>
          <input type="email" id="email" name="email" placeholder="seu@email.com" required />
        </fieldset>

        <!-- TELEFONE -->
        <fieldset class="form-field r">
          <label for="telefone">Telefone com WhatsApp *</label>
          <input type="tel" id="telefone" name="telefone" placeholder="(XX) 98000-0000" required />
        </fieldset>

        <!-- ESTADO -->
        <fieldset class="form-field r">
          <label for="estado">Em qual estado você está? *</label>
          <select id="estado" name="estado" required>
            <option value="">Selecione seu estado</option>
            <option value="AC">Acre</option>
            <option value="AL">Alagoas</option>
            <option value="AP">Amapá</option>
            <option value="AM">Amazonas</option>
            <option value="BA">Bahia</option>
            <option value="CE">Ceará</option>
            <option value="DF">Distrito Federal</option>
            <option value="ES">Espírito Santo</option>
            <option value="GO">Goiás</option>
            <option value="MA">Maranhão</option>
            <option value="MT">Mato Grosso</option>
            <option value="MS">Mato Grosso do Sul</option>
            <option value="MG">Minas Gerais</option>
            <option value="PA">Pará</option>
            <option value="PB">Paraíba</option>
            <option value="PR">Paraná</option>
            <option value="PE">Pernambuco</option>
            <option value="PI">Piauí</option>
            <option value="RJ">Rio de Janeiro</option>
            <option value="RN">Rio Grande do Norte</option>
            <option value="RS">Rio Grande do Sul</option>
            <option value="RO">Rondônia</option>
            <option value="RR">Roraima</option>
            <option value="SC">Santa Catarina</option>
            <option value="SP">São Paulo</option>
            <option value="SE">Sergipe</option>
            <option value="TO">Tocantins</option>
          </select>
        </fieldset>

        <!-- DESCRIÇÃO DA QUEIXA -->
        <fieldset class="form-field r">
          <label for="descricaoQueixa">O que o traz até aqui? *</label>
          <textarea id="descricaoQueixa" name="descricaoQueixa" placeholder="Descreva seu problema capilar, há quanto tempo, se já fez algum tratamento..." rows="4" required></textarea>
        </fieldset>

        <!-- DATA PREFERÊNCIA -->
        <fieldset class="form-field r">
          <label for="dataPreferencia">Data preferida para avaliação</label>
          <input type="date" id="dataPreferencia" name="dataPreferencia" />
        </fieldset>

        <!-- SUBMIT -->
        <button type="submit" class="btn btn-primary r d2">agendar online</button>

        <p class="form-notice r d3">
          Suas informações são confidenciais. Confirmaremos via WhatsApp em até 24h com link de acesso e instruções de preparação.
        </p>
      </form>

      <!-- SUCCESS MESSAGE -->
      <div class="ecooa-form-ok" style="display:none">
        <div class="form-success r d1">
          <h3>Perfeito!</h3>
          <p>Recebemos sua solicitação de consulta online. Entraremos em contato em até 24h via WhatsApp para confirmar horário e compartilhar o link de telemedicina.</p>
          <a href={WA_DEFAULT} target="_blank" rel="noopener noreferrer" class="btn btn-primary">confirmar via WhatsApp</a>
        </div>
      </div>
    </div>

    <!-- QUICK CONTACT ALTERNATIVE -->
    <div class="form-alternative r d3">
      <p>Prefere agendar direto?</p>
      <a href={WA_DEFAULT} target="_blank" rel="noopener noreferrer" class="btn btn-outline">conversar no WhatsApp</a>
    </div>
  </section>

  <script>
    import '../../scripts/form-submit';
  </script>

  <style is:inline>
    /* HERO ========================================== */
    .form-hero {
      min-height: 45vh;
      background: var(--c-black);
      padding: clamp(4rem, 10vh, 7rem) var(--section-px);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .form-hero-content {
      max-width: 760px;
    }
    .form-hero-title {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: clamp(36px, 5vw, 68px);
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: var(--c-beige);
      margin: 0 0 var(--space-md);
    }
    .form-hero-title em { font-style: italic; color: var(--c-gold); }
    .form-hero-lead {
      font-size: 16px;
      line-height: 1.8;
      color: var(--color-ink-soft);
      margin: 0;
    }

    /* FORM =========================================== */
    .form-container {
      max-width: 640px;
      margin: 0 auto;
      background: var(--c-beige);
      padding: var(--space-xl);
    }
    .form-header {
      margin-bottom: var(--space-xl);
    }
    .form-header h2 {
      font-family: var(--font-serif);
      font-size: 28px;
      font-weight: 400;
      color: var(--c-black);
      margin: 0 0 8px;
    }
    .form-header p {
      font-size: 14px;
      color: rgba(11,11,11,.7);
      margin: 0;
    }

    .ecooa-form {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }
    .form-field {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin: 0;
      border: none;
      padding: 0;
    }
    .form-field label {
      font-size: 13px;
      font-weight: 500;
      color: var(--c-black);
      letter-spacing: .02em;
    }
    .form-field input,
    .form-field select,
    .form-field textarea {
      padding: 12px 14px;
      border: 1px solid rgba(11,11,11,.2);
      background: var(--c-white);
      color: var(--c-black);
      font-family: var(--font-primary);
      font-size: 14px;
      border-radius: 0;
      transition: border-color var(--transition-fast);
    }
    .form-field input:focus,
    .form-field select:focus,
    .form-field textarea:focus {
      outline: none;
      border-color: var(--c-gold);
      box-shadow: inset 0 0 0 1px var(--c-gold);
    }
    .form-field textarea {
      resize: vertical;
      font-family: var(--font-primary);
    }

    .form-notice {
      font-size: 12px;
      color: rgba(11,11,11,.6);
      text-align: center;
      line-height: 1.6;
      margin-top: var(--space-lg);
    }

    .form-success {
      background: var(--c-white);
      padding: var(--space-xl);
      border-left: 4px solid var(--c-gold);
      text-align: center;
    }
    .form-success h3 {
      font-family: var(--font-serif);
      font-size: 28px;
      font-weight: 400;
      color: var(--c-black);
      margin: 0 0 var(--space-sm);
    }
    .form-success p {
      font-size: 14px;
      color: rgba(11,11,11,.7);
      margin: 0 0 var(--space-lg);
      line-height: 1.7;
    }

    /* ALTERNATIVE ==================================== */
    .form-alternative {
      text-align: center;
      margin-top: var(--space-xl);
    }
    .form-alternative p {
      font-size: 14px;
      color: rgba(11,11,11,.7);
      margin: 0 0 var(--space-md);
    }
  </style>

</BaseLayout>
