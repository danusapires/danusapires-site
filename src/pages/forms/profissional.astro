---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE, FORM_TYPES, WA_DEFAULT } from '../../data/site';

const formConfig = FORM_TYPES.professionalInquiry;
---

<BaseLayout
  title="Contato profissional | Danusa Pires"
  description="Médicos, dermatologistas e profissionais de saúde. Protocolo de encaminhamento, parceria clínica e educação continuada."
  currentPage="contato-profissional"
  breadcrumbs={[
    { name: 'Contato profissional', url: '/forms/profissional' }
  ]}
>

  <!-- HERO -->
  <section class="form-hero">
    <div class="form-hero-content">
      <p class="lbl r">para profissionais</p>
      <h1 class="form-hero-title r d1">
        Rede clínica de <em>referência</em>.
      </h1>
      <p class="form-hero-lead r d2">
        Dermatologistas, médicos, nutricionistas: compartilhamos diagnóstico clínico estruturado e continuidade. Encaminhamentos. Educação continuada. Parcerias terapêuticas que respeitam autonomia clínica.
      </p>
    </div>
  </section>

  <!-- FORM SECTION -->
  <section style="padding:var(--section-py) var(--section-px)">
    <div class="form-container r d1">
      <div class="form-header">
        <h2>Entre em contato</h2>
        <p>Preenchemos que seu interesse e entraremos em contato para estruturar parceria ou educação continuada.</p>
      </div>

      <form class="ecooa-form" action={SITE.gasUrl} method="POST">
        <input type="hidden" name="_formType" value={formConfig.id} />

        <!-- NOME -->
        <fieldset class="form-field r">
          <label for="nome">Nome completo *</label>
          <input type="text" id="nome" name="nome" placeholder="Dr./Dra. [Nome]" required />
        </fieldset>

        <!-- PROFISSÃO -->
        <fieldset class="form-field r">
          <label for="profissao">Profissão *</label>
          <select id="profissao" name="profissao" required>
            <option value="">Selecione sua profissão</option>
            <option value="Dermatologista">Dermatologista</option>
            <option value="Cirurgião">Cirurgião capilar</option>
            <option value="Médico clínico">Médico clínico</option>
            <option value="Nutricionista">Nutricionista</option>
            <option value="Farmacêutico">Farmacêutico</option>
            <option value="Esteticien">Esteticien</option>
            <option value="Fisioterapeuta">Fisioterapeuta</option>
            <option value="Outro">Outro profissional de saúde</option>
          </select>
        </fieldset>

        <!-- ESPECIALIZAÇÃO -->
        <fieldset class="form-field r">
          <label for="especializacao">Sua especialização *</label>
          <input type="text" id="especializacao" name="especializacao" placeholder="Ex: Dermatologia clínica, Tricologia, Cirurgia capilar" required />
        </fieldset>

        <!-- EMAIL -->
        <fieldset class="form-field r">
          <label for="email">Email profissional *</label>
          <input type="email" id="email" name="email" placeholder="seu@clinica.com.br" required />
        </fieldset>

        <!-- TELEFONE -->
        <fieldset class="form-field r">
          <label for="telefone">Telefone/WhatsApp *</label>
          <input type="tel" id="telefone" name="telefone" placeholder="(51) 98016-4433" required />
        </fieldset>

        <!-- DESCRIÇÃO DE INTERESSE -->
        <fieldset class="form-field r">
          <label for="descricaoInteresse">Qual seu interesse? *</label>
          <textarea id="descricaoInteresse" name="descricaoInteresse" placeholder="Encaminhamento de pacientes, educação continuada, parceria em pesquisa, publicações..." rows="4" required></textarea>
        </fieldset>

        <!-- SUBMIT -->
        <button type="submit" class="btn btn-primary r d2">enviar consulta</button>

        <p class="form-notice r d3">
          Seus dados são confidenciais e usados apenas para contato profissional.
        </p>
      </form>

      <!-- SUCCESS MESSAGE -->
      <div class="ecooa-form-ok" style="display:none">
        <div class="form-success r d1">
          <h3>Obrigado!</h3>
          <p>Recebemos sua consulta profissional. Nossa equipe entrará em contato em até 48h para discutir possibilidades de parceria ou educação continuada.</p>
          <a href={WA_DEFAULT} target="_blank" rel="noopener noreferrer" class="btn btn-primary">conversar via WhatsApp</a>
        </div>
      </div>
    </div>

    <!-- QUICK CONTACT ALTERNATIVE -->
    <div class="form-alternative r d3">
      <p>Prefere falar direto?</p>
      <a href={WA_DEFAULT} target="_blank" rel="noopener noreferrer" class="btn btn-outline">conversar no WhatsApp</a>
    </div>
  </section>

  <script>
    import '../../scripts/form-submit';
  </script>

  <style is:inline>
    /* HERO ========================================== */
    .form-hero {
      min-height: 45vh;
      background: var(--c-black);
      padding: clamp(4rem, 10vh, 7rem) var(--section-px);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .form-hero-content {
      max-width: 760px;
    }
    .form-hero-title {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: clamp(36px, 5vw, 68px);
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: var(--c-beige);
      margin: 0 0 var(--space-md);
    }
    .form-hero-title em { font-style: italic; color: var(--c-gold); }
    .form-hero-lead {
      font-size: 16px;
      line-height: 1.8;
      color: var(--color-ink-soft);
      margin: 0;
    }

    /* FORM =========================================== */
    .form-container {
      max-width: 640px;
      margin: 0 auto;
      background: var(--c-beige);
      padding: var(--space-xl);
    }
    .form-header {
      margin-bottom: var(--space-xl);
    }
    .form-header h2 {
      font-family: var(--font-serif);
      font-size: 28px;
      font-weight: 400;
      color: var(--c-black);
      margin: 0 0 8px;
    }
    .form-header p {
      font-size: 14px;
      color: rgba(11,11,11,.7);
      margin: 0;
    }

    .ecooa-form {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }
    .form-field {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin: 0;
      border: none;
      padding: 0;
    }
    .form-field label {
      font-size: 13px;
      font-weight: 500;
      color: var(--c-black);
      letter-spacing: .02em;
    }
    .form-field input,
    .form-field select,
    .form-field textarea {
      padding: 12px 14px;
      border: 1px solid rgba(11,11,11,.2);
      background: var(--c-white);
      color: var(--c-black);
      font-family: var(--font-primary);
      font-size: 14px;
      border-radius: 0;
      transition: border-color var(--transition-fast);
    }
    .form-field input:focus,
    .form-field select:focus,
    .form-field textarea:focus {
      outline: none;
      border-color: var(--c-gold);
      box-shadow: inset 0 0 0 1px var(--c-gold);
    }
    .form-field textarea {
      resize: vertical;
      font-family: var(--font-primary);
    }

    .form-notice {
      font-size: 12px;
      color: rgba(11,11,11,.6);
      text-align: center;
      line-height: 1.6;
      margin-top: var(--space-lg);
    }

    .form-success {
      background: var(--c-white);
      padding: var(--space-xl);
      border-left: 4px solid var(--c-gold);
      text-align: center;
    }
    .form-success h3 {
      font-family: var(--font-serif);
      font-size: 28px;
      font-weight: 400;
      color: var(--c-black);
      margin: 0 0 var(--space-sm);
    }
    .form-success p {
      font-size: 14px;
      color: rgba(11,11,11,.7);
      margin: 0 0 var(--space-lg);
      line-height: 1.7;
    }

    /* ALTERNATIVE ==================================== */
    .form-alternative {
      text-align: center;
      margin-top: var(--space-xl);
    }
    .form-alternative p {
      font-size: 14px;
      color: rgba(11,11,11,.7);
      margin: 0 0 var(--space-md);
    }
  </style>

</BaseLayout>
