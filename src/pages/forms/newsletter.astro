---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE, FORM_TYPES } from '../../data/site';

const formConfig = FORM_TYPES.newsletter;
---

<BaseLayout
  title="Newsletter | Danusa Pires"
  description="Receba artigos e atualizações clínicas sobre tricologia, saúde capilar e bem-estar. Conteúdo exclusivo em seu email."
  currentPage="newsletter"
  breadcrumbs={[
    { name: 'Newsletter', url: '/forms/newsletter' }
  ]}
>

  <!-- HERO -->
  <section class="form-hero">
    <div class="form-hero-content">
      <p class="lbl r">inscreva-se</p>
      <h1 class="form-hero-title r d1">
        Conteúdo clínico no seu <em>email</em>.
      </h1>
      <p class="form-hero-lead r d2">
        Artigos sobre tricologia, saúde capilar integrada, estudos de caso, protocolos. Conteúdo exclusivo enviado 2x por mês para quem realmente quer entender o cabelo.
      </p>
    </div>
  </section>

  <!-- FORM SECTION -->
  <section style="padding:var(--section-py) var(--section-px)">
    <div class="form-container r d1">
      <div class="form-header">
        <h2>Receba nossos artigos</h2>
        <p>Inscreva-se na newsletter clínica. Conteúdo prático sobre diagnóstico, tratamento e filosofia de cuidado.</p>
      </div>

      <form class="ecooa-form" action={SITE.gasUrl} method="POST">
        <input type="hidden" name="_formType" value={formConfig.id} />

        <!-- NOME -->
        <fieldset class="form-field r">
          <label for="nome">Seu nome *</label>
          <input type="text" id="nome" name="nome" placeholder="Como podemos chamá-lo?" required />
        </fieldset>

        <!-- EMAIL -->
        <fieldset class="form-field r">
          <label for="email">Seu melhor email *</label>
          <input type="email" id="email" name="email" placeholder="seu@email.com" required />
        </fieldset>

        <!-- SUBMIT -->
        <button type="submit" class="btn btn-primary r d2">inscrever-se</button>

        <p class="form-notice r d3">
          Você receberá artigos clínicos 2x por mês. Sem spam. Cancelar inscrição a qualquer momento.
        </p>
      </form>

      <!-- SUCCESS MESSAGE -->
      <div class="ecooa-form-ok" style="display:none">
        <div class="form-success r d1">
          <h3>Bem-vindo!</h3>
          <p>Sua inscrição foi confirmada. Você receberá nossos artigos clínicos em até 48h. Obrigado por se conectar com nosso conteúdo.</p>
        </div>
      </div>
    </div>

    <!-- NEWSLETTER PREVIEW -->
    <div style="max-width:760px;margin:var(--space-xl) auto;padding:var(--space-lg);background:var(--c-beige);border:1px solid rgba(11,11,11,.08)">
      <h3 style="font-family:var(--font-serif);font-size:18px;color:var(--c-black);margin:0 0 var(--space-md)">O que você receberá:</h3>
      <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:var(--space-sm)">
        <li style="font-size:14px;color:rgba(11,11,11,.7);margin:0">📚 Artigos aprofundados sobre mecanismos capilares</li>
        <li style="font-size:14px;color:rgba(11,11,11,.7);margin:0">🔬 Estudos clínicos comentados</li>
        <li style="font-size:14px;color:rgba(11,11,11,.7);margin:0">💡 Protocolos estruturados e atualizações de prática</li>
        <li style="font-size:14px;color:rgba(11,11,11,.7);margin:0">🌱 Perspectiva de saúde integrativa</li>
        <li style="font-size:14px;color:rgba(11,11,11,.7);margin:0">👥 Cases clínicos e lições aprendidas</li>
      </ul>
    </div>
  </section>

  <script>
    import '../../scripts/form-submit';
  </script>

  <style is:inline>
    /* HERO ========================================== */
    .form-hero {
      min-height: 45vh;
      background: var(--c-black);
      padding: clamp(4rem, 10vh, 7rem) var(--section-px);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .form-hero-content {
      max-width: 760px;
    }
    .form-hero-title {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: clamp(36px, 5vw, 68px);
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: var(--c-beige);
      margin: 0 0 var(--space-md);
    }
    .form-hero-title em { font-style: italic; color: var(--c-gold); }
    .form-hero-lead {
      font-size: 16px;
      line-height: 1.8;
      color: var(--color-ink-soft);
      margin: 0;
    }

    /* FORM =========================================== */
    .form-container {
      max-width: 640px;
      margin: 0 auto;
      background: var(--c-beige);
      padding: var(--space-xl);
    }
    .form-header {
      margin-bottom: var(--space-xl);
    }
    .form-header h2 {
      font-family: var(--font-serif);
      font-size: 28px;
      font-weight: 400;
      color: var(--c-black);
      margin: 0 0 8px;
    }
    .form-header p {
      font-size: 14px;
      color: rgba(11,11,11,.7);
      margin: 0;
    }

    .ecooa-form {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }
    .form-field {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin: 0;
      border: none;
      padding: 0;
    }
    .form-field label {
      font-size: 13px;
      font-weight: 500;
      color: var(--c-black);
      letter-spacing: .02em;
    }
    .form-field input,
    .form-field select,
    .form-field textarea {
      padding: 12px 14px;
      border: 1px solid rgba(11,11,11,.2);
      background: var(--c-white);
      color: var(--c-black);
      font-family: var(--font-primary);
      font-size: 14px;
      border-radius: 0;
      transition: border-color var(--transition-fast);
    }
    .form-field input:focus,
    .form-field select:focus,
    .form-field textarea:focus {
      outline: none;
      border-color: var(--c-gold);
      box-shadow: inset 0 0 0 1px var(--c-gold);
    }
    .form-field textarea {
      resize: vertical;
      font-family: var(--font-primary);
    }

    .form-notice {
      font-size: 12px;
      color: rgba(11,11,11,.6);
      text-align: center;
      line-height: 1.6;
      margin-top: var(--space-lg);
    }

    .form-success {
      background: var(--c-white);
      padding: var(--space-xl);
      border-left: 4px solid var(--c-gold);
      text-align: center;
    }
    .form-success h3 {
      font-family: var(--font-serif);
      font-size: 28px;
      font-weight: 400;
      color: var(--c-black);
      margin: 0 0 var(--space-sm);
    }
    .form-success p {
      font-size: 14px;
      color: rgba(11,11,11,.7);
      margin: 0;
      line-height: 1.7;
    }
  </style>

</BaseLayout>
