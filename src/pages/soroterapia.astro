---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';
import { WA_DEFAULT, SITE } from '../data/site';

/**
 * Soroterapia, sistema smart.soro.
 * O paciente seleciona a queixa principal → recebe lista orientativa de ativos pertinentes.
 * IMPORTANTE: a lista é orientativa. A composição final só é definida em avaliação clínica.
 *
 * [PENDENTE: validar lista de ativos com a Danusa Pires antes do go-live]
 */

interface Queixa {
  slug: string;
  label: string;
  ativos: { nome: string; mecanismo: string }[];
}

const queixas: Queixa[] = [
  {
    slug: 'queda-capilar',
    label: 'Queda capilar e fragilidade dos fios',
    ativos: [
      { nome: 'Biotina', mecanismo: 'Cofator no metabolismo da queratina' },
      { nome: 'Zinco quelado', mecanismo: 'Suporte enzimático ao folículo' },
      { nome: 'Vitamina D3', mecanismo: 'Modulação do ciclo folicular' },
      { nome: 'Cisteína / Metionina', mecanismo: 'Aminoácidos sulfurados estruturais' },
      { nome: 'Ferro bisglicinato', mecanismo: 'Quando há ferritina baixa documentada' },
    ],
  },
  {
    slug: 'fadiga-disposicao',
    label: 'Fadiga, baixa disposição, recuperação',
    ativos: [
      { nome: 'Complexo B', mecanismo: 'Suporte energético mitocondrial' },
      { nome: 'Magnésio quelado', mecanismo: 'Cofator de mais de 300 reações enzimáticas' },
      { nome: 'Vitamina C alta dose', mecanismo: 'Antioxidante e suporte adrenal' },
      { nome: 'Taurina', mecanismo: 'Modulação do estresse oxidativo' },
    ],
  },
  {
    slug: 'pele-envelhecimento',
    label: 'Pele, envelhecimento e oxidação',
    ativos: [
      { nome: 'Glutationa', mecanismo: 'Antioxidante mestre, desintoxicação' },
      { nome: 'Ácido alfa lipoico', mecanismo: 'Antioxidante hidro e lipossolúvel' },
      { nome: 'Vitamina C', mecanismo: 'Cofator do colágeno' },
      { nome: 'Selenoproteína', mecanismo: 'Defesa antioxidante celular' },
    ],
  },
  {
    slug: 'imunidade-recorrencia',
    label: 'Imunidade baixa ou episódios recorrentes',
    ativos: [
      { nome: 'Vitamina D3', mecanismo: 'Modulação imune' },
      { nome: 'Zinco', mecanismo: 'Função de linfócitos T' },
      { nome: 'Vitamina C', mecanismo: 'Suporte de neutrófilos' },
      { nome: 'NAC (N-acetilcisteína)', mecanismo: 'Precursor de glutationa' },
    ],
  },
  {
    slug: 'pre-pos-procedimento',
    label: 'Pré e pós-procedimento (estético ou capilar)',
    ativos: [
      { nome: 'Vitamina C', mecanismo: 'Síntese de colágeno na cicatrização' },
      { nome: 'Aminoácidos essenciais', mecanismo: 'Substrato para reparo tecidual' },
      { nome: 'Glutationa', mecanismo: 'Modulação inflamatória' },
      { nome: 'Zinco', mecanismo: 'Cicatrização e reparo' },
    ],
  },
  {
    slug: 'longevidade',
    label: 'Longevidade e manutenção preventiva',
    ativos: [
      { nome: 'NAD+ precursores', mecanismo: 'Suporte mitocondrial' },
      { nome: 'Glutationa', mecanismo: 'Antioxidante celular' },
      { nome: 'Multivitamínico EV', mecanismo: 'Reposição programada conforme avaliação' },
    ],
  },
];
---

<BaseLayout
  title="Soroterapia individualizada · Sistema smart.soro"
  description="Soroterapia conforme avaliação clínica. Sistema smart.soro orienta os ativos pertinentes ao quadro. Composição final definida sempre em consulta. Sede em Porto Alegre, Edifício Moinhos 180."
  currentPage="soroterapia"
  breadcrumbs={[{ name: 'Soroterapia', url: '/soroterapia' }]}
>

  <!-- HERO -->
  <section class="sr-hero">
    <div class="sr-hero-content">
      <p class="lbl r">soroterapia · sistema smart.soro</p>
      <h1 class="sr-hero-title r d1">
        Soroterapia <em>individualizada</em>,<br>
        não fórmula de prateleira.
      </h1>
      <p class="sr-hero-lead r d2">
        Soroterapia faz parte do plano clínico apenas quando a avaliação justifica. A composição é definida conforme histórico, exames pertinentes e padrão fisiológico individual. O sistema smart.soro abaixo orienta os ativos potencialmente pertinentes ao seu quadro, a fórmula final só é definida em consulta.
      </p>
      <div class="sr-hero-actions r d3">
        <a href="#match" class="btn btn-primary">explorar smart.soro</a>
        <a href={WA_DEFAULT} target="_blank" rel="noopener noreferrer" class="dh-hero-link">conversar pelo WhatsApp →</a>
      </div>
    </div>
    <div class="sr-hero-image" aria-hidden="true">
      <picture>
        <source srcset="/images/clinical/serum-application.avif" type="image/avif" />
        <source srcset="/images/clinical/serum-application.webp" type="image/webp" />
        <img src="/images/clinical/serum-application.webp" alt="" fetchpriority="high" decoding="async" />
      </picture>
    </div>
  </section>

  <!-- SISTEMA SORO-MATCH -->
  <section id="match" class="section-cream">
    <div style="max-width:780px">
      <p class="lbl r">sistema smart.soro</p>
      <h2 class="section-title r d1">Selecione a queixa. <em>Veja</em> os ativos pertinentes.</h2>
      <p class="section-subtitle r d2">A leitura é orientativa, não prescritiva. Evita expectativa cega e dá referência técnica do que pode entrar na composição. A definição final acontece em avaliação clínica, conforme histórico, exames e padrão individual.</p>
    </div>

    <div class="sm-wrap r d2">
      <div class="sm-queixas" role="tablist" aria-label="Queixas">
        {queixas.map((q, i) => (
          <button
            class:list={['sm-queixa', { active: i === 0 }]}
            type="button"
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            data-target={q.slug}
            id={`tab-${q.slug}`}
          >
            <span class="sm-queixa-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="sm-queixa-label">{q.label}</span>
          </button>
        ))}
      </div>

      <div class="sm-results">
        {queixas.map((q, i) => (
          <div
            class:list={['sm-panel', { active: i === 0 }]}
            data-panel={q.slug}
            role="tabpanel"
            aria-labelledby={`tab-${q.slug}`}
            hidden={i !== 0}
          >
            <p class="sm-panel-eyebrow">ativos potencialmente pertinentes</p>
            <h3 class="sm-panel-title">{q.label}</h3>
            <ul class="sm-ativos">
              {q.ativos.map(a => (
                <li>
                  <strong>{a.nome}</strong>
                  <span>{a.mecanismo}</span>
                </li>
              ))}
            </ul>
            <p class="sm-disclaimer">
              A combinação, doses e via de administração são definidas em avaliação clínica. Resposta variável conforme padrão fisiológico individual.
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMO FUNCIONA -->
  <section>
    <div style="max-width:780px">
      <p class="lbl r">como funciona</p>
      <h2 class="section-title r d1">Da anamnese à <em>aplicação</em>.</h2>
    </div>

    <ol class="dh-flow r d1">
      <li><span>01</span><div><strong>Anamnese e indicação</strong>Levantamento clínico, leitura de exames quando houver, definição se a soroterapia faz sentido no plano.</div></li>
      <li><span>02</span><div><strong>Composição individualizada</strong>Ativos, dose e via de administração definidos conforme o caso, não há fórmula única.</div></li>
      <li><span>03</span><div><strong>Aplicação na sala dedicada</strong>Ambiente projetado para o tempo de cada sessão. Aplicação conduzida pela equipe técnica com monitoramento.</div></li>
      <li><span>04</span><div><strong>Plano de continuidade</strong>Quando há indicação de ciclo, frequência e marcadores de acompanhamento são definidos no protocolo.</div></li>
    </ol>
  </section>

  <!-- FAQ -->
  <section class="section-cream">
    <div style="max-width:760px">
      <p class="lbl r">dúvidas frequentes</p>
      <h2 class="section-title r d1">Antes da <em>primeira</em> aplicação.</h2>
    </div>

    <div class="sr-faq">
      <details class="sr-faq-item r" open>
        <summary><span>Qualquer pessoa pode fazer soroterapia?</span><span class="ic">+</span></summary>
        <p>Não. Há contraindicações que precisam ser avaliadas em anamnese, função renal, função hepática, alergias específicas, gestação, uso de medicamentos. A primeira consulta é obrigatória antes de qualquer aplicação.</p>
      </details>
      <details class="sr-faq-item r d1">
        <summary><span>Quanto tempo dura uma sessão?</span><span class="ic">+</span></summary>
        <p>Em média entre 40 e 90 minutos, conforme a composição e o volume. A sala foi pensada para que esse tempo seja confortável.</p>
      </details>
      <details class="sr-faq-item r d2">
        <summary><span>O sistema smart.soro substitui a consulta?</span><span class="ic">+</span></summary>
        <p>Não. É uma ferramenta orientativa que mostra ativos potencialmente pertinentes. A composição final, dose, via de administração e frequência são definidas em avaliação clínica.</p>
      </details>
      <details class="sr-faq-item r d3">
        <summary><span>Combina com tratamento capilar?</span><span class="ic">+</span></summary>
        <p>Em muitos casos sim. A soroterapia entra como suporte interno em planos de tricologia, com cronograma alinhado às demais sessões. A indicação parte do plano integrado, não isolada.</p>
      </details>
    </div>
  </section>

  <CtaSection
    heading="Soroterapia parte da <em>anamnese</em>, não do cardápio."
    subtext="A primeira consulta avalia se faz sentido para o seu caso, define a composição e o cronograma. Conversa pelo WhatsApp adianta a triagem."
  />

  <script>
    const tabs = document.querySelectorAll('.sm-queixa');
    const panels = document.querySelectorAll('.sm-panel');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-target');
        tabs.forEach(t => {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        panels.forEach(p => {
          p.classList.remove('active');
          p.setAttribute('hidden', '');
        });
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');
        const panel = document.querySelector(`[data-panel="${target}"]`);
        if (panel) {
          panel.classList.add('active');
          panel.removeAttribute('hidden');
        }
      });
    });
  </script>

  <style>
    /* HERO */
    .sr-hero {
      min-height: 88vh;
      display: grid;
      grid-template-columns: 1.05fr 1fr;
      background: var(--c-black);
      overflow: hidden;
    }
    .sr-hero-content {
      padding: clamp(7rem, 14vh, 10rem) clamp(2rem, 6vw, 5rem) clamp(3rem, 8vh, 5rem);
      display: flex;
      flex-direction: column;
      justify-content: center;
      max-width: 760px;
      position: relative;
      z-index: 2;
    }
    .sr-hero-title {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: clamp(36px, 5.2vw, 76px);
      line-height: 1.04;
      letter-spacing: -0.018em;
      color: var(--c-beige);
      margin: 0 0 var(--space-md);
    }
    .sr-hero-title em { font-style: italic; color: var(--c-gold); }
    .sr-hero-lead {
      font-size: 16px;
      line-height: 1.85;
      color: var(--color-ink-soft);
      max-width: 580px;
      margin-bottom: var(--space-lg);
    }
    .sr-hero-actions {
      display: flex;
      align-items: center;
      gap: 28px;
      flex-wrap: wrap;
    }
    .dh-hero-link {
      font-family: var(--font-primary);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--c-beige);
      border-bottom: 1px solid var(--c-gold);
      padding-bottom: 4px;
      transition: color var(--transition-fast);
    }
    .dh-hero-link:hover { color: var(--c-gold); }
    .sr-hero-image { position: relative; overflow: hidden; background: var(--c-graphite); }
    .sr-hero-image picture, .sr-hero-image img {
      width: 100%; height: 100%; object-fit: cover; display: block;
    }
    .sr-hero-image::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(270deg, transparent 60%, rgba(11,11,11,0.7) 100%);
    }
    @media (max-width: 960px) {
      .sr-hero { grid-template-columns: 1fr; min-height: auto; }
      .sr-hero-image { aspect-ratio: 4/5; order: -1; }
      .sr-hero-content { padding-top: 6rem; }
    }

    /* SORO-MATCH */
    .sm-wrap {
      display: grid;
      grid-template-columns: 380px 1fr;
      gap: 1px;
      background: rgba(11,11,11,.12);
      border: 1px solid rgba(11,11,11,.12);
      margin-top: var(--space-xl);
      min-height: 480px;
    }
    .sm-queixas {
      background: var(--c-white);
      display: flex;
      flex-direction: column;
    }
    .sm-queixa {
      background: transparent;
      border: 0;
      border-bottom: 1px solid rgba(11,11,11,.08);
      padding: 22px 28px;
      text-align: left;
      cursor: pointer;
      display: flex;
      align-items: flex-start;
      gap: 16px;
      transition: background .2s;
      font-family: inherit;
    }
    .sm-queixa:hover { background: rgba(198,168,90,.06); }
    .sm-queixa.active {
      background: var(--c-black);
      color: var(--c-beige);
    }
    .sm-queixa.active .sm-queixa-num { color: var(--c-gold); }
    .sm-queixa.active .sm-queixa-label { color: var(--c-beige); }
    .sm-queixa-num {
      font-family: var(--font-serif);
      font-size: 22px;
      color: var(--c-gold);
      line-height: 1;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .sm-queixa-label {
      font-family: var(--font-serif);
      font-size: 17px;
      line-height: 1.3;
      color: var(--c-black);
    }

    .sm-results {
      background: var(--c-white);
      padding: 48px 56px;
    }
    .sm-panel { display: none; }
    .sm-panel.active { display: block; }
    .sm-panel-eyebrow {
      font-family: var(--font-primary);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--c-gold);
      margin-bottom: 12px;
    }
    .sm-panel-title {
      font-family: var(--font-serif);
      font-size: 28px;
      font-weight: 400;
      color: var(--c-black);
      margin-bottom: var(--space-lg);
      line-height: 1.2;
    }
    .sm-ativos {
      list-style: none;
      padding: 0;
      margin: 0 0 var(--space-lg);
      display: flex;
      flex-direction: column;
      gap: 0;
      border-top: 1px solid rgba(11,11,11,.08);
    }
    .sm-ativos li {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 24px;
      padding: 16px 0;
      border-bottom: 1px solid rgba(11,11,11,.08);
      align-items: baseline;
    }
    .sm-ativos strong {
      font-family: var(--font-serif);
      font-size: 19px;
      font-weight: 400;
      color: var(--c-black);
    }
    .sm-ativos span {
      font-size: 14px;
      color: rgba(11,11,11,.65);
      line-height: 1.7;
    }
    .sm-disclaimer {
      font-size: 12px;
      color: rgba(11,11,11,.55);
      line-height: 1.7;
      font-style: italic;
      max-width: 60ch;
      padding-top: var(--space-md);
      border-top: 1px solid rgba(11,11,11,.08);
    }

    @media (max-width: 800px) {
      .sm-wrap { grid-template-columns: 1fr; }
      .sm-results { padding: 32px 28px; }
      .sm-ativos li { grid-template-columns: 1fr; gap: 4px; }
    }

    /* FLOW */
    .dh-flow { list-style: none; margin: var(--space-lg) 0 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-md); max-width: 800px; }
    .dh-flow li {
      display: grid;
      grid-template-columns: 56px 1fr;
      gap: var(--space-md);
      padding: var(--space-md) 0;
      border-bottom: 1px solid rgba(232,227,220,.1);
    }
    .dh-flow li:last-child { border-bottom: 0; }
    .dh-flow span {
      font-family: var(--font-serif);
      font-size: 26px;
      font-weight: 400;
      color: var(--c-gold);
    }
    .dh-flow strong {
      display: block;
      font-family: var(--font-serif);
      font-size: 19px;
      font-weight: 400;
      color: var(--c-beige);
      margin-bottom: 6px;
    }
    .dh-flow div { font-size: 14px; line-height: 1.8; color: var(--color-ink-soft); }

    /* FAQ */
    .sr-faq { max-width: 780px; margin: var(--space-xl) auto 0; }
    .sr-faq-item { border-bottom: 1px solid rgba(11,11,11,.12); }
    .sr-faq-item summary {
      list-style: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-md);
      padding: var(--space-md) 0;
      font-family: var(--font-primary);
      font-size: 15px;
      font-weight: 400;
      color: var(--c-black);
    }
    .sr-faq-item summary::-webkit-details-marker { display: none; }
    .sr-faq-item summary:hover { color: var(--c-gold); }
    .sr-faq-item .ic {
      color: var(--c-gold);
      font-size: 22px;
      transition: transform var(--transition-base);
    }
    .sr-faq-item[open] .ic { transform: rotate(45deg); }
    .sr-faq-item p {
      padding-bottom: var(--space-md);
      padding-right: 40px;
      font-size: 14px;
      color: rgba(11,11,11,.72);
      line-height: 1.85;
      max-width: 60ch;
    }
  </style>

</BaseLayout>
