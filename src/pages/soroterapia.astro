---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaSection from "../components/CtaSection.astro";
import { WA_DEFAULT, SITE } from "../data/site";
import { resolveQueixas, getDominiosCount } from "../data/smart-soro";

/**
 * Soroterapia, sistema smart.soro.
 * Dados (catálogo de ATIVOS + mapeamento QUEIXAS) vivem em src/data/smart-soro/.
 * Ver src/data/smart-soro/README.md para arquitetura, técnica de busca e guardrails éticos.
 */

const queixas = resolveQueixas();
const dominios = getDominiosCount();
---

<BaseLayout
  title="Soroterapia individualizada · Sistema smart.soro"
  description="Soroterapia conforme avaliação clínica. Sistema smart.soro orienta os ativos pertinentes ao quadro. Composição final definida sempre em consulta. Sede em Porto Alegre, Edifício Moinhos 180."
  currentPage="soroterapia"
  breadcrumbs={[{ name: 'Soroterapia', url: '/soroterapia' }]}
>

  <!-- HERO -->
  <section class="sr-hero">
    <div class="sr-hero-content">
      <p class="lbl r">soroterapia · sistema smart.soro</p>
      <h1 class="sr-hero-title r d1">
        Soroterapia <em>individualizada</em>,<br>
        não fórmula de prateleira.
      </h1>
      <p class="sr-hero-lead r d2">
        smart.soro é um sistema de consulta livre: você digita qualquer queixa &mdash; capilar, fadiga, ansiedade, dor de cabeça, performance, sono, imunidade, hormonal, pós-procedimento &mdash; e vê os ativos que podem entrar em uma composição de soro. <strong>É leitura técnica, não prescrição.</strong> A composição final, dose e via só são definidas em avaliação clínica.
      </p>
      <div class="sr-hero-actions r d3">
        <a href="#match" class="btn btn-primary">explorar smart.soro</a>
        <a href={WA_DEFAULT} target="_blank" rel="noopener noreferrer" class="dh-hero-link">conversar pelo WhatsApp →</a>
      </div>
    </div>
    <div class="sr-hero-image" aria-hidden="true">
      <picture>
        <source srcset="/images/clinical/serum-application.avif" type="image/avif" />
        <source srcset="/images/clinical/serum-application.webp" type="image/webp" />
        <img src="/images/clinical/serum-application.webp" alt="" fetchpriority="high" decoding="async" />
      </picture>
    </div>
  </section>

  <!-- SISTEMA SORO-MATCH -->
  <section id="match" class="section-cream">
    <div style="max-width:780px">
      <p class="lbl r">sistema smart.soro</p>
      <h2 class="section-title r d1">Digite sua queixa. <em>Veja</em> os ativos pertinentes.</h2>
      <p class="section-subtitle r d2">{queixas.length} quadros cobertos em {dominios} domínios: capilar, energia, sono, hormonal, performance, imunidade, pele, intestino, longevidade, perioperatório, gestação, pós-viral.</p>
    </div>

    <!-- AVISO ÉTICO DESTACADO -->
    <div class="sm-ethical-notice r d1" style="max-width:780px;margin-top:var(--space-lg)">
      <p class="sm-ethical-title">⚠ Importante &mdash; leia antes de usar</p>
      <ul class="sm-ethical-list">
        <li><strong>Não é diagnóstico.</strong> Esta ferramenta lista ativos com plausibilidade técnica para cada quadro. Não substitui consulta, exame ou prescrição.</li>
        <li><strong>Não inicie protocolo por conta própria.</strong> A composição final, dose, via de administração, frequência e contraindicações são definidas por profissional habilitado em avaliação clínica presencial.</li>
        <li><strong>Há contraindicações sérias.</strong> Função renal, função hepática, alergias, gestação, lactação e uso de medicamentos podem inviabilizar ativos listados aqui.</li>
        <li><strong>Casos urgentes:</strong> dor intensa, febre persistente, sintomas neurológicos novos &mdash; procure pronto-atendimento, não soroterapia.</li>
      </ul>
    </div>

    <div class="sm-search-container r d2" style="margin-top:var(--space-lg);max-width:780px">
      <input
        type="text"
        id="sm-search"
        class="sm-search-input"
        placeholder="Ex: dor de cabeça, queda, ansiedade, sono, libido, treino, menopausa, jet lag..."
        aria-label="Buscar queixa"
        autocomplete="off"
      />
      <div class="sm-search-hint">Comece digitando para ver as sugestões. Aceita sinônimos.</div>
    </div>

    <div class="sm-results-container r d2" style="margin-top:var(--space-lg);max-width:780px">
      {queixas.map((q, i) => (
        <div class="sm-result-item" data-queixa={q.slug} data-search={[q.label, ...q.tags].join(' | ').toLowerCase()}>
          <p class="sm-panel-eyebrow">ativos potencialmente pertinentes</p>
          <h3 class="sm-panel-title">{q.label}</h3>
          <ul class="sm-ativos">
            {q.ativos.map(a => (
              <li>
                <strong>{a.nome}</strong>
                <span>{a.observacao || a.mecanismo}</span>
              </li>
            ))}
          </ul>
          <p class="sm-disclaimer">
            A combinação, doses e via de administração são definidas em avaliação clínica. Resposta variável conforme padrão fisiológico individual.
          </p>
        </div>
      ))}
    </div>

    <div id="sm-no-results" class="sm-no-results" style="display:none;margin-top:var(--space-lg);text-align:center">
      <p style="font-size:16px;color:rgba(11,11,11,.6)">Nenhuma queixa encontrada com esses termos. <a href="/agendamento" style="color:var(--c-gold);text-decoration:underline">Fale com a equipe</a> &mdash; o cardápio coberto aqui não é exaustivo.</p>
    </div>
  </section>

  <!-- COMO FUNCIONA -->
  <section>
    <div style="max-width:780px">
      <p class="lbl r">como funciona</p>
      <h2 class="section-title r d1">Da anamnese à <em>aplicação</em>.</h2>
    </div>

    <ol class="dh-flow r d1">
      <li><span>01</span><div><strong>Anamnese e indicação</strong>Levantamento clínico, leitura de exames quando houver, definição se a soroterapia faz sentido no plano.</div></li>
      <li><span>02</span><div><strong>Composição individualizada</strong>Ativos, dose e via de administração definidos conforme o caso, não há fórmula única.</div></li>
      <li><span>03</span><div><strong>Aplicação na sala dedicada</strong>Ambiente projetado para o tempo de cada sessão. Aplicação conduzida pela equipe técnica com monitoramento.</div></li>
      <li><span>04</span><div><strong>Plano de continuidade</strong>Quando há indicação de ciclo, frequência e marcadores de acompanhamento são definidos no protocolo.</div></li>
    </ol>
  </section>

  <!-- FAQ -->
  <section class="section-cream">
    <div style="max-width:760px">
      <p class="lbl r">dúvidas frequentes</p>
      <h2 class="section-title r d1">Antes da <em>primeira</em> aplicação.</h2>
    </div>

    <div class="sr-faq">
      <details class="sr-faq-item r" open>
        <summary><span>Qualquer pessoa pode fazer soroterapia?</span><span class="ic">+</span></summary>
        <p>Não. Há contraindicações que precisam ser avaliadas em anamnese, função renal, função hepática, alergias específicas, gestação, uso de medicamentos. A primeira consulta é obrigatória antes de qualquer aplicação.</p>
      </details>
      <details class="sr-faq-item r d1">
        <summary><span>Quanto tempo dura uma sessão?</span><span class="ic">+</span></summary>
        <p>Em média entre 40 e 90 minutos, conforme a composição e o volume. A sala foi pensada para que esse tempo seja confortável.</p>
      </details>
      <details class="sr-faq-item r d2">
        <summary><span>O sistema smart.soro substitui a consulta?</span><span class="ic">+</span></summary>
        <p>Não. É uma ferramenta orientativa que mostra ativos potencialmente pertinentes. A composição final, dose, via de administração e frequência são definidas em avaliação clínica.</p>
      </details>
      <details class="sr-faq-item r d3">
        <summary><span>Combina com tratamento capilar?</span><span class="ic">+</span></summary>
        <p>Em muitos casos sim. A soroterapia entra como suporte interno em planos de tricologia, com cronograma alinhado às demais sessões. A indicação parte do plano integrado, não isolada.</p>
      </details>
    </div>
  </section>

  <CtaSection
    heading="Soroterapia parte da <em>anamnese</em>, não do cardápio."
    subtext="A primeira consulta avalia se faz sentido para o seu caso, define a composição e o cronograma. Conversa pelo WhatsApp adianta a triagem."
  />

  <script>
    const searchInput = document.getElementById('sm-search') as HTMLInputElement;
    const resultItems = document.querySelectorAll('.sm-result-item');
    const noResultsDiv = document.getElementById('sm-no-results');

    // Normaliza string: minúsculas + remove acentos
    function normalize(s: string): string {
      return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
    }

    // Tokeniza query em palavras (>=2 chars)
    function tokenize(s: string): string[] {
      return normalize(s).split(/\s+/).filter(w => w.length >= 2);
    }

    searchInput?.addEventListener('input', (e) => {
      const raw = (e.target as HTMLInputElement).value.trim();
      const tokens = tokenize(raw);
      let visibleCount = 0;

      resultItems.forEach(item => {
        const haystack = normalize(item.getAttribute('data-search') || '');
        // Sem query: mostra tudo. Com query: todas as palavras precisam aparecer no haystack.
        const matches = tokens.length === 0 || tokens.every(t => haystack.includes(t));

        (item as HTMLElement).style.display = matches ? 'block' : 'none';
        if (matches) visibleCount++;
      });

      if (noResultsDiv) {
        noResultsDiv.style.display = (visibleCount === 0 && tokens.length > 0) ? 'block' : 'none';
      }
    });
  </script>

  <style>
    /* HERO */
    .sr-hero {
      min-height: 88vh;
      display: grid;
      grid-template-columns: 1.05fr 1fr;
      background: var(--c-black);
      overflow: hidden;
    }
    .sr-hero-content {
      padding: clamp(7rem, 14vh, 10rem) clamp(2rem, 6vw, 5rem) clamp(3rem, 8vh, 5rem);
      display: flex;
      flex-direction: column;
      justify-content: center;
      max-width: 760px;
      position: relative;
      z-index: 2;
    }
    .sr-hero-title {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: clamp(36px, 5.2vw, 76px);
      line-height: 1.04;
      letter-spacing: -0.018em;
      color: var(--c-beige);
      margin: 0 0 var(--space-md);
    }
    .sr-hero-title em { font-style: italic; color: var(--c-gold); }
    .sr-hero-lead {
      font-size: 16px;
      line-height: 1.85;
      color: var(--color-ink-soft);
      max-width: 580px;
      margin-bottom: var(--space-lg);
    }
    .sr-hero-actions {
      display: flex;
      align-items: center;
      gap: 28px;
      flex-wrap: wrap;
    }
    .dh-hero-link {
      font-family: var(--font-primary);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--c-beige);
      border-bottom: 1px solid var(--c-gold);
      padding-bottom: 4px;
      transition: color var(--transition-fast);
    }
    .dh-hero-link:hover { color: var(--c-gold); }
    .sr-hero-image { position: relative; overflow: hidden; background: var(--c-graphite); }
    .sr-hero-image picture, .sr-hero-image img {
      width: 100%; height: 100%; object-fit: cover; display: block;
    }
    .sr-hero-image::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(270deg, transparent 60%, rgba(11,11,11,0.7) 100%);
    }
    @media (max-width: 960px) {
      .sr-hero { grid-template-columns: 1fr; min-height: auto; }
      .sr-hero-image { aspect-ratio: 4/5; order: -1; }
      .sr-hero-content { padding-top: 6rem; }
    }

    /* SORO-MATCH */
    .sm-wrap {
      display: grid;
      grid-template-columns: 380px 1fr;
      gap: 1px;
      background: rgba(11,11,11,.12);
      border: 1px solid rgba(11,11,11,.12);
      margin-top: var(--space-xl);
      min-height: 480px;
    }
    .sm-queixas {
      background: var(--c-white);
      display: flex;
      flex-direction: column;
    }
    .sm-queixa {
      background: transparent;
      border: 0;
      border-bottom: 1px solid rgba(11,11,11,.08);
      padding: 22px 28px;
      text-align: left;
      cursor: pointer;
      display: flex;
      align-items: flex-start;
      gap: 16px;
      transition: background .2s;
      font-family: inherit;
    }
    .sm-queixa:hover { background: rgba(198,168,90,.06); }
    .sm-queixa.active {
      background: var(--c-black);
      color: var(--c-beige);
    }
    .sm-queixa.active .sm-queixa-num { color: var(--c-gold); }
    .sm-queixa.active .sm-queixa-label { color: var(--c-beige); }
    .sm-queixa-num {
      font-family: var(--font-serif);
      font-size: 22px;
      color: var(--c-gold);
      line-height: 1;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .sm-queixa-label {
      font-family: var(--font-serif);
      font-size: 17px;
      line-height: 1.3;
      color: var(--c-black);
    }

    .sm-results {
      background: var(--c-white);
      padding: 48px 56px;
    }
    .sm-panel { display: none; }
    .sm-panel.active { display: block; }
    .sm-panel-eyebrow {
      font-family: var(--font-primary);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--c-gold);
      margin-bottom: 12px;
    }
    .sm-panel-title {
      font-family: var(--font-serif);
      font-size: 28px;
      font-weight: 400;
      color: var(--c-black);
      margin-bottom: var(--space-lg);
      line-height: 1.2;
    }
    .sm-ativos {
      list-style: none;
      padding: 0;
      margin: 0 0 var(--space-lg);
      display: flex;
      flex-direction: column;
      gap: 0;
      border-top: 1px solid rgba(11,11,11,.08);
    }
    .sm-ativos li {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 24px;
      padding: 16px 0;
      border-bottom: 1px solid rgba(11,11,11,.08);
      align-items: baseline;
    }
    .sm-ativos strong {
      font-family: var(--font-serif);
      font-size: 19px;
      font-weight: 400;
      color: var(--c-black);
    }
    .sm-ativos span {
      font-size: 14px;
      color: rgba(11,11,11,.65);
      line-height: 1.7;
    }
    .sm-disclaimer {
      font-size: 12px;
      color: rgba(11,11,11,.55);
      line-height: 1.7;
      font-style: italic;
      max-width: 60ch;
      padding-top: var(--space-md);
      border-top: 1px solid rgba(11,11,11,.08);
    }

    /* ETHICAL NOTICE BOX */
    .sm-ethical-notice {
      background: #1a1208;
      color: #f0e4cd;
      padding: clamp(1.25rem, 3vw, 1.75rem);
      border-left: 4px solid var(--c-gold);
    }
    .sm-ethical-title {
      font-family: var(--font-primary);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--c-gold);
      margin: 0 0 12px;
    }
    .sm-ethical-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .sm-ethical-list li {
      font-size: 13.5px;
      line-height: 1.65;
      color: rgba(240, 228, 205, 0.85);
      padding-left: 14px;
      position: relative;
    }
    .sm-ethical-list li::before {
      content: '·';
      position: absolute;
      left: 0;
      color: var(--c-gold);
      font-weight: 700;
    }
    .sm-ethical-list strong {
      color: #f0e4cd;
      font-weight: 600;
    }

    /* SEARCH INTERFACE */
    .sm-search-container {
      position: relative;
    }
    .sm-search-input {
      width: 100%;
      padding: 18px 20px;
      font-family: var(--font-primary);
      font-size: 16px;
      border: 2px solid rgba(11,11,11,.12);
      border-radius: 2px;
      background: var(--c-white);
      color: var(--c-black);
      transition: border-color var(--transition-base);
    }
    .sm-search-input:focus {
      outline: none;
      border-color: var(--c-gold);
    }
    .sm-search-input::placeholder {
      color: rgba(11,11,11,.45);
    }
    .sm-search-hint {
      margin-top: 10px;
      font-size: 13px;
      color: rgba(11,11,11,.55);
      font-style: italic;
    }

    .sm-results-container {
      display: flex;
      flex-direction: column;
      gap: var(--space-lg);
    }
    .sm-result-item {
      padding: var(--space-lg);
      background: var(--c-white);
      border: 1px solid rgba(11,11,11,.08);
      border-radius: 2px;
      transition: border-color var(--transition-base), background var(--transition-base);
    }
    .sm-result-item:hover {
      border-color: var(--c-gold);
      background: rgba(198,168,90,.02);
    }

    .sm-no-results {
      padding: var(--space-lg);
      background: rgba(11,11,11,.03);
      border-radius: 2px;
      text-align: center;
    }

    @media (max-width: 800px) {
      .sm-wrap { grid-template-columns: 1fr; }
      .sm-results { padding: 32px 28px; }
      .sm-ativos li { grid-template-columns: 1fr; gap: 4px; }
      .sm-search-input { font-size: 16px; padding: 16px 18px; }
    }

    /* FLOW */
    .dh-flow { list-style: none; margin: var(--space-lg) 0 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-md); max-width: 800px; }
    .dh-flow li {
      display: grid;
      grid-template-columns: 56px 1fr;
      gap: var(--space-md);
      padding: var(--space-md) 0;
      border-bottom: 1px solid rgba(232,227,220,.1);
    }
    .dh-flow li:last-child { border-bottom: 0; }
    .dh-flow span {
      font-family: var(--font-serif);
      font-size: 26px;
      font-weight: 400;
      color: var(--c-gold);
    }
    .dh-flow strong {
      display: block;
      font-family: var(--font-serif);
      font-size: 19px;
      font-weight: 400;
      color: var(--c-beige);
      margin-bottom: 6px;
    }
    .dh-flow div { font-size: 14px; line-height: 1.8; color: var(--color-ink-soft); }

    /* FAQ */
    .sr-faq { max-width: 780px; margin: var(--space-xl) auto 0; }
    .sr-faq-item { border-bottom: 1px solid rgba(11,11,11,.12); }
    .sr-faq-item summary {
      list-style: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-md);
      padding: var(--space-md) 0;
      font-family: var(--font-primary);
      font-size: 15px;
      font-weight: 400;
      color: var(--c-black);
    }
    .sr-faq-item summary::-webkit-details-marker { display: none; }
    .sr-faq-item summary:hover { color: var(--c-gold); }
    .sr-faq-item .ic {
      color: var(--c-gold);
      font-size: 22px;
      transition: transform var(--transition-base);
    }
    .sr-faq-item[open] .ic { transform: rotate(45deg); }
    .sr-faq-item p {
      padding-bottom: var(--space-md);
      padding-right: 40px;
      font-size: 14px;
      color: rgba(11,11,11,.72);
      line-height: 1.85;
      max-width: 60ch;
    }
  </style>

</BaseLayout>
