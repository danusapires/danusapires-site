---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaSection from "../components/CtaSection.astro";
import { WA_DEFAULT, SITE } from "../data/site";
import { resolveQueixas, getDominiosCount } from "../data/smart-soro";

/**
 * Soroterapia, sistema smart.soro.
 * Dados (catálogo de ATIVOS + mapeamento QUEIXAS) vivem em src/data/smart-soro/.
 * Ver src/data/smart-soro/README.md para arquitetura, técnica de busca e guardrails éticos.
 */

const queixas = resolveQueixas();
const dominios = getDominiosCount();
---

<BaseLayout
  title="Soroterapia individualizada · Sistema smart.soro"
  description="Soroterapia conforme avaliação clínica. Sistema smart.soro orienta os ativos pertinentes ao quadro. Composição final definida sempre em consulta. Sede em Porto Alegre, Edifício Moinhos 180."
  currentPage="soroterapia"
  breadcrumbs={[{ name: 'Soroterapia', url: '/soroterapia' }]}
>

  <!-- HERO -->
  <section class="sr-hero">
    <div class="sr-hero-content">
      <p class="lbl r">soroterapia · sistema smart.soro</p>
      <h1 class="sr-hero-title r d1">
        Soroterapia <em>individualizada</em>,<br>
        não fórmula de prateleira.
      </h1>
      <p class="sr-hero-lead r d2">
        smart.soro é um sistema de consulta livre: você digita qualquer queixa &mdash; capilar, fadiga, ansiedade, dor de cabeça, performance, sono, imunidade, hormonal, pós-procedimento &mdash; e vê os ativos que podem entrar em uma composição de soro. <strong>É leitura técnica, não prescrição.</strong> A composição final, dose e via só são definidas em avaliação clínica.
      </p>
      <div class="sr-hero-actions r d3">
        <a href="#match" class="btn btn-primary">explorar smart.soro</a>
        <a href={WA_DEFAULT} target="_blank" rel="noopener noreferrer" class="dh-hero-link">conversar pelo WhatsApp →</a>
      </div>
    </div>
    <div class="sr-hero-image" aria-hidden="true">
      <picture>
        <source srcset="/images/clinical/serum-application.avif" type="image/avif" />
        <source srcset="/images/clinical/serum-application.webp" type="image/webp" />
        <img src="/images/clinical/serum-application.webp" alt="" fetchpriority="high" decoding="async" />
      </picture>
    </div>
  </section>

  <!-- SISTEMA SORO-MATCH -->
  <section id="match" class="section-cream">
    <div class="sm-wrap">
      <p class="lbl r">sistema smart.soro</p>
      <h2 class="section-title r d1">Digite sua queixa. <em>Veja</em> os ativos pertinentes.</h2>
      <p class="section-subtitle r d2">{queixas.length} quadros cobertos em {dominios} domínios. Sistema multi-domínio: capilar, energia, sono, hormonal, performance, imunidade, pele, intestino, longevidade, perioperatório, pós-bariátrico, emagrecimento.</p>
    </div>

    <!-- AVISO ÉTICO DESTACADO -->
    <div class="sm-ethical-notice r d1 sm-wrap" style="margin-top:var(--space-lg)">
      <p class="sm-ethical-title">⚠ Importante &mdash; leia antes de usar</p>
      <ul class="sm-ethical-list">
        <li><strong>Não é diagnóstico.</strong> Esta ferramenta lista ativos com plausibilidade técnica para cada quadro. Não substitui consulta, exame ou prescrição.</li>
        <li><strong>Não inicie protocolo por conta própria.</strong> A composição final, dose, via de administração, frequência e contraindicações são definidas por profissional habilitado em avaliação clínica presencial.</li>
        <li><strong>Há contraindicações sérias.</strong> Função renal, função hepática, alergias, gestação, lactação e uso de medicamentos podem inviabilizar ativos listados aqui.</li>
        <li><strong>Casos urgentes:</strong> dor intensa, febre persistente, sintomas neurológicos novos &mdash; procure pronto-atendimento, não soroterapia.</li>
      </ul>
    </div>

    <div class="sm-search-container r d2 sm-wrap" style="margin-top:var(--space-lg)">
      <label for="sm-search" class="sm-search-label">O que você está sentindo?</label>
      <input
        type="text"
        id="sm-search"
        class="sm-search-input"
        placeholder="Ex: dor de cabeça forte, acordo cansado, queda capilar, libido baixa, compulsão por doce..."
        aria-label="Buscar queixa em linguagem natural"
        autocomplete="off"
      />
      <p class="sm-search-hint">Escreva como você falaria com a médica. Aceita acento ou sem.</p>

      <!-- CHIPS DE SUGESTÃO -->
      <div class="sm-chips" role="group" aria-label="Sugestões de busca">
        <button type="button" class="sm-chip" data-q="queda capilar">queda capilar</button>
        <button type="button" class="sm-chip" data-q="acordo cansado">acordo cansado</button>
        <button type="button" class="sm-chip" data-q="dor de cabeça">dor de cabeça</button>
        <button type="button" class="sm-chip" data-q="compulsão por doce">compulsão por doce</button>
        <button type="button" class="sm-chip" data-q="memória ruim">memória ruim</button>
        <button type="button" class="sm-chip" data-q="emagrecimento">emagrecimento</button>
        <button type="button" class="sm-chip" data-q="menopausa">menopausa</button>
        <button type="button" class="sm-chip" data-q="pós bariátrica">pós bariátrica</button>
        <button type="button" class="sm-chip" data-q="longevidade">longevidade</button>
        <button type="button" class="sm-chip" data-q="performance">performance</button>
      </div>

      <!-- CONTADOR -->
      <p id="sm-counter" class="sm-counter" aria-live="polite">{queixas.length} quadros disponíveis</p>
    </div>

    <div class="sm-results-container r d2 sm-wrap" style="margin-top:var(--space-lg)">
      {queixas.map((q) => (
        <article
          class="sm-result-item"
          data-queixa={q.slug}
          data-dominio={q.dominio}
          data-search={[q.label, ...q.tags].join(' | ').toLowerCase()}
        >
          <header class="sm-result-head">
            <p class="sm-panel-eyebrow">{q.dominio.replace(/-/g, ' · ')}</p>
            <h3 class="sm-panel-title">{q.label}</h3>
          </header>

          <ul class="sm-ativos">
            {q.ativos.map(a => (
              <li class="sm-ativo">
                <div class="sm-ativo-head">
                  <strong class="sm-ativo-nome">{a.nome}</strong>
                  <span class="sm-ativo-cat">{a.categoria}</span>
                </div>
                <p class="sm-ativo-mec">{a.observacao || a.mecanismo}</p>
                <details class="sm-ativo-more">
                  <summary>indicação de uso</summary>
                  <p>{a.indicacaoUso}</p>
                </details>
              </li>
            ))}
          </ul>

          <p class="sm-disclaimer">
            A combinação, doses e via de administração são definidas em avaliação clínica. Resposta variável conforme padrão fisiológico individual.
          </p>
        </article>
      ))}
    </div>

    <!-- EMPTY STATE / CTA WHATSAPP -->
    <div id="sm-no-results" class="sm-no-results sm-wrap" style="display:none;margin-top:var(--space-lg)">
      <p class="sm-no-results-title">Não encontrei correspondência para o que você digitou.</p>
      <p class="sm-no-results-lead">O cardápio coberto aqui não é exaustivo. A composição certa para você pode existir mesmo que a queixa exata não esteja mapeada.</p>
      <div class="sm-no-results-actions">
        <a href={WA_DEFAULT} target="_blank" rel="noopener noreferrer" class="btn btn-primary">falar pelo WhatsApp</a>
        <a href="/agendamento" class="sm-no-results-link">ou agendar avaliação →</a>
      </div>
    </div>
  </section>

  <!-- COMO FUNCIONA -->
  <section>
    <div style="max-width:780px">
      <p class="lbl r">como funciona</p>
      <h2 class="section-title r d1">Da anamnese à <em>aplicação</em>.</h2>
    </div>

    <ol class="dh-flow r d1">
      <li><span>01</span><div><strong>Anamnese e indicação</strong>Levantamento clínico, leitura de exames quando houver, definição se a soroterapia faz sentido no plano.</div></li>
      <li><span>02</span><div><strong>Composição individualizada</strong>Ativos, dose e via de administração definidos conforme o caso, não há fórmula única.</div></li>
      <li><span>03</span><div><strong>Aplicação na sala dedicada</strong>Ambiente projetado para o tempo de cada sessão. Aplicação conduzida pela equipe técnica com monitoramento.</div></li>
      <li><span>04</span><div><strong>Plano de continuidade</strong>Quando há indicação de ciclo, frequência e marcadores de acompanhamento são definidos no protocolo.</div></li>
    </ol>
  </section>

  <!-- FAQ -->
  <section class="section-cream">
    <div style="max-width:760px">
      <p class="lbl r">dúvidas frequentes</p>
      <h2 class="section-title r d1">Antes da <em>primeira</em> aplicação.</h2>
    </div>

    <div class="sr-faq">
      <details class="sr-faq-item r" open>
        <summary><span>Qualquer pessoa pode fazer soroterapia?</span><span class="ic">+</span></summary>
        <p>Não. Há contraindicações que precisam ser avaliadas em anamnese, função renal, função hepática, alergias específicas, gestação, uso de medicamentos. A primeira consulta é obrigatória antes de qualquer aplicação.</p>
      </details>
      <details class="sr-faq-item r d1">
        <summary><span>Quanto tempo dura uma sessão?</span><span class="ic">+</span></summary>
        <p>Em média entre 40 e 90 minutos, conforme a composição e o volume. A sala foi pensada para que esse tempo seja confortável.</p>
      </details>
      <details class="sr-faq-item r d2">
        <summary><span>O sistema smart.soro substitui a consulta?</span><span class="ic">+</span></summary>
        <p>Não. É uma ferramenta orientativa que mostra ativos potencialmente pertinentes. A composição final, dose, via de administração e frequência são definidas em avaliação clínica.</p>
      </details>
      <details class="sr-faq-item r d3">
        <summary><span>Combina com tratamento capilar?</span><span class="ic">+</span></summary>
        <p>Em muitos casos sim. A soroterapia entra como suporte interno em planos de tricologia, com cronograma alinhado às demais sessões. A indicação parte do plano integrado, não isolada.</p>
      </details>
    </div>
  </section>

  <CtaSection
    heading="Soroterapia parte da <em>anamnese</em>, não do cardápio."
    subtext="A primeira consulta avalia se faz sentido para o seu caso, define a composição e o cronograma. Conversa pelo WhatsApp adianta a triagem."
  />

  <script>
    /**
     * smart.soro · busca em linguagem natural
     * - normaliza acentos
     * - filtra stopwords PT-BR + qualificadores
     * - tokeniza por whitespace + pontuação
     * - match AND (todas as palavras precisam aparecer)
     * - fallback OR se zero matches (mostra "aproximados")
     * - empty state com CTA WhatsApp
     * - chips de sugestão clicáveis
     * - contador ao vivo
     */

    const searchInput = document.getElementById('sm-search') as HTMLInputElement | null;
    const resultItems = Array.from(document.querySelectorAll<HTMLElement>('.sm-result-item'));
    const noResultsDiv = document.getElementById('sm-no-results');
    const counter = document.getElementById('sm-counter');
    const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.sm-chip'));

    const TOTAL = resultItems.length;

    const STOPWORDS = new Set([
      'de','da','do','das','dos','a','o','as','os','um','uma','uns','umas',
      'para','pra','pro','por','pelo','pela','pelos','pelas',
      'com','sem','em','no','na','nos','nas','num','numa',
      'e','ou','mas','que','se','ao','aos',
      'meu','minha','seu','sua','eu','me','te','lhe','isso','isto','aquilo',
      'muito','muita','muitos','muitas','pouco','pouca','poucos','poucas',
      'mais','menos','tao','tão','bem','mal',
      'forte','fraco','fraca','leve','severo','severa','grave','pesado','pesada',
      'intenso','intensa','horrível','horrivel','terrível','terrivel',
      'sempre','nunca','jamais','frequente','frequentemente',
      'estou','esta','está','sou','sinto','sentindo',
      'tenho','tem','tinha','foi','ser','estar','fica','fico','ando',
      'preciso','quero','queria','gostaria',
      'nao','não','consigo','consegue','pode','posso',
      'extremo','extrema','pequeno','pequena','grande','pouquinho',
      'pre','pré','pós','pos',
      'oi','olá','ola','bom','dia','tarde','noite',
    ]);

    const normalize = (s: string) => s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');

    const tokenize = (s: string): string[] =>
      normalize(s)
        .split(/[\s,.;!?:()\-]+/)
        .filter(w => w.length >= 3 && !STOPWORDS.has(w));

    const setVisible = (el: HTMLElement, on: boolean, approx = false) => {
      el.style.display = on ? 'block' : 'none';
      el.classList.toggle('sm-approx', approx);
    };

    const updateCounter = (matchCount: number, tokens: string[], mode: 'all' | 'exact' | 'approx' | 'none') => {
      if (!counter) return;
      if (mode === 'all') {
        counter.textContent = `${TOTAL} quadros disponíveis`;
        counter.className = 'sm-counter';
      } else if (mode === 'exact') {
        counter.textContent = `${matchCount} ${matchCount === 1 ? 'quadro encontrado' : 'quadros encontrados'} para "${tokens.join(' ')}"`;
        counter.className = 'sm-counter sm-counter-exact';
      } else if (mode === 'approx') {
        counter.textContent = `Sem match exato. Mostrando ${matchCount} ${matchCount === 1 ? 'quadro aproximado' : 'quadros aproximados'}.`;
        counter.className = 'sm-counter sm-counter-approx';
      } else {
        counter.textContent = `Nenhum quadro casa com "${tokens.join(' ')}". Fale com a equipe.`;
        counter.className = 'sm-counter sm-counter-none';
      }
    };

    const runSearch = (raw: string) => {
      const tokens = tokenize(raw);

      // Sem tokens significativos: exibe tudo.
      if (tokens.length === 0) {
        resultItems.forEach(el => setVisible(el, true, false));
        if (noResultsDiv) noResultsDiv.style.display = 'none';
        updateCounter(TOTAL, [], 'all');
        return;
      }

      // 1ª passada: AND estrito (todas as palavras precisam aparecer)
      const matchesAnd: HTMLElement[] = [];
      const matchesOr: HTMLElement[] = [];
      resultItems.forEach(el => {
        const haystack = normalize(el.getAttribute('data-search') || '');
        const allTokens = tokens.every(t => haystack.includes(t));
        const anyToken = tokens.some(t => haystack.includes(t));
        if (allTokens) matchesAnd.push(el);
        else if (anyToken) matchesOr.push(el);
      });

      if (matchesAnd.length > 0) {
        // Exibe AND-matches em modo exato
        resultItems.forEach(el => setVisible(el, matchesAnd.includes(el), false));
        if (noResultsDiv) noResultsDiv.style.display = 'none';
        updateCounter(matchesAnd.length, tokens, 'exact');
      } else if (matchesOr.length > 0) {
        // Fallback: mostra OR-matches como "aproximados"
        resultItems.forEach(el => setVisible(el, matchesOr.includes(el), true));
        if (noResultsDiv) noResultsDiv.style.display = 'none';
        updateCounter(matchesOr.length, tokens, 'approx');
      } else {
        // Zero matches: esconde tudo + mostra empty state com CTA
        resultItems.forEach(el => setVisible(el, false, false));
        if (noResultsDiv) noResultsDiv.style.display = 'block';
        updateCounter(0, tokens, 'none');
      }
    };

    // input do usuário (com debounce leve via requestAnimationFrame)
    let raf = 0;
    searchInput?.addEventListener('input', (e) => {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => runSearch((e.target as HTMLInputElement).value.trim()));
    });

    // chips clicáveis preenchem o input e disparam busca
    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        const q = chip.getAttribute('data-q') || '';
        if (searchInput) {
          searchInput.value = q;
          searchInput.focus();
        }
        runSearch(q);
        // scroll suave para os resultados
        document.querySelector('.sm-results-container')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    // estado inicial
    updateCounter(TOTAL, [], 'all');
  </script>

  <style>
    /* HERO */
    .sr-hero {
      min-height: 88vh;
      display: grid;
      grid-template-columns: 1.05fr 1fr;
      background: var(--c-black);
      overflow: hidden;
    }
    .sr-hero-content {
      padding: clamp(7rem, 14vh, 10rem) clamp(2rem, 6vw, 5rem) clamp(3rem, 8vh, 5rem);
      display: flex;
      flex-direction: column;
      justify-content: center;
      max-width: 760px;
      position: relative;
      z-index: 2;
    }
    .sr-hero-title {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: clamp(36px, 5.2vw, 76px);
      line-height: 1.04;
      letter-spacing: -0.018em;
      color: var(--c-beige);
      margin: 0 0 var(--space-md);
    }
    .sr-hero-title em { font-style: italic; color: var(--c-gold); }
    .sr-hero-lead {
      font-size: 16px;
      line-height: 1.85;
      color: var(--color-ink-soft);
      max-width: 580px;
      margin-bottom: var(--space-lg);
    }
    .sr-hero-actions {
      display: flex;
      align-items: center;
      gap: 28px;
      flex-wrap: wrap;
    }
    .dh-hero-link {
      font-family: var(--font-primary);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--c-beige);
      border-bottom: 1px solid var(--c-gold);
      padding-bottom: 4px;
      transition: color var(--transition-fast);
    }
    .dh-hero-link:hover { color: var(--c-gold); }
    .sr-hero-image { position: relative; overflow: hidden; background: var(--c-graphite); }
    .sr-hero-image picture, .sr-hero-image img {
      width: 100%; height: 100%; object-fit: cover; display: block;
    }
    .sr-hero-image::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(270deg, transparent 60%, rgba(11,11,11,0.7) 100%);
    }
    @media (max-width: 960px) {
      .sr-hero { grid-template-columns: 1fr; min-height: auto; }
      .sr-hero-image { aspect-ratio: 4/5; order: -1; }
      .sr-hero-content { padding-top: 6rem; }
    }

    /* SORO-MATCH */
    .sm-wrap {
      display: grid;
      grid-template-columns: 380px 1fr;
      gap: 1px;
      background: rgba(11,11,11,.12);
      border: 1px solid rgba(11,11,11,.12);
      margin-top: var(--space-xl);
      min-height: 480px;
    }
    .sm-queixas {
      background: var(--c-white);
      display: flex;
      flex-direction: column;
    }
    .sm-queixa {
      background: transparent;
      border: 0;
      border-bottom: 1px solid rgba(11,11,11,.08);
      padding: 22px 28px;
      text-align: left;
      cursor: pointer;
      display: flex;
      align-items: flex-start;
      gap: 16px;
      transition: background .2s;
      font-family: inherit;
    }
    .sm-queixa:hover { background: rgba(198,168,90,.06); }
    .sm-queixa.active {
      background: var(--c-black);
      color: var(--c-beige);
    }
    .sm-queixa.active .sm-queixa-num { color: var(--c-gold); }
    .sm-queixa.active .sm-queixa-label { color: var(--c-beige); }
    .sm-queixa-num {
      font-family: var(--font-serif);
      font-size: 22px;
      color: var(--c-gold);
      line-height: 1;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .sm-queixa-label {
      font-family: var(--font-serif);
      font-size: 17px;
      line-height: 1.3;
      color: var(--c-black);
    }

    .sm-results {
      background: var(--c-white);
      padding: 48px 56px;
    }
    .sm-panel { display: none; }
    .sm-panel.active { display: block; }
    .sm-panel-eyebrow {
      font-family: var(--font-primary);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--c-gold);
      margin-bottom: 12px;
    }
    .sm-panel-title {
      font-family: var(--font-serif);
      font-size: 28px;
      font-weight: 400;
      color: var(--c-black);
      margin-bottom: var(--space-lg);
      line-height: 1.2;
    }
    .sm-ativos {
      list-style: none;
      padding: 0;
      margin: 0 0 var(--space-lg);
      display: flex;
      flex-direction: column;
      gap: 0;
      border-top: 1px solid rgba(11,11,11,.08);
    }
    .sm-ativos li {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 24px;
      padding: 16px 0;
      border-bottom: 1px solid rgba(11,11,11,.08);
      align-items: baseline;
    }
    .sm-ativos strong {
      font-family: var(--font-serif);
      font-size: 19px;
      font-weight: 400;
      color: var(--c-black);
    }
    .sm-ativos span {
      font-size: 14px;
      color: rgba(11,11,11,.65);
      line-height: 1.7;
    }
    .sm-disclaimer {
      font-size: 12px;
      color: rgba(11,11,11,.55);
      line-height: 1.7;
      font-style: italic;
      max-width: 60ch;
      padding-top: var(--space-md);
      border-top: 1px solid rgba(11,11,11,.08);
    }

    /* ETHICAL NOTICE BOX */
    .sm-ethical-notice {
      background: #1a1208;
      color: #f0e4cd;
      padding: clamp(1.25rem, 3vw, 1.75rem);
      border-left: 4px solid var(--c-gold);
    }
    .sm-ethical-title {
      font-family: var(--font-primary);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--c-gold);
      margin: 0 0 12px;
    }
    .sm-ethical-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .sm-ethical-list li {
      font-size: 13.5px;
      line-height: 1.65;
      color: rgba(240, 228, 205, 0.85);
      padding-left: 14px;
      position: relative;
    }
    .sm-ethical-list li::before {
      content: '·';
      position: absolute;
      left: 0;
      color: var(--c-gold);
      font-weight: 700;
    }
    .sm-ethical-list strong {
      color: #f0e4cd;
      font-weight: 600;
    }

    /* WRAPPER COMUM */
    .sm-wrap { max-width: 920px; margin-left: auto; margin-right: auto; }

    /* SEARCH INTERFACE */
    .sm-search-container {
      position: relative;
    }
    .sm-search-label {
      display: block;
      font-family: var(--font-primary);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--c-black);
      margin-bottom: 10px;
    }
    .sm-search-input {
